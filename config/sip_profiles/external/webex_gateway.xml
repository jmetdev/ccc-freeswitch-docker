<include>
  <!--
    Webex Calling registration-based trunk (Local Gateway).
    Fill in the webex_* values in vars.xml; this file should not need edits.

    Registration model per Cisco's LGW spec:
      - REGISTER over TLS 1.2 via the outbound proxy (DNS SRV resolves port 8934)
      - AOR / Contact user = Line/Port; digest auth uses the separate trunk
        username (Webex challenges with realm "BroadWorks")
      - 240s expiry, re-registered by FreeSWITCH before it lapses
      - SRTP is mandatory with AES_CM_128_HMAC_SHA1_80
    No client certificate is required for registration-based trunks.
  -->
  <gateway name="webex">
    <!-- AOR being registered: the Line/Port user part -->
    <param name="username" value="$${webex_line_port}"/>
    <!-- Digest credentials from Control Hub -->
    <param name="auth-username" value="$${webex_username}"/>
    <param name="password" value="$${webex_password}"/>
    <param name="realm" value="$${webex_registrar}"/>
    <param name="from-user" value="$${webex_line_port}"/>
    <param name="from-domain" value="$${webex_registrar}"/>
    <param name="proxy" value="$${webex_registrar}"/>
    <param name="outbound-proxy" value="$${webex_outbound_proxy}"/>
    <param name="register" value="true"/>
    <param name="register-transport" value="tls"/>
    <param name="expire-seconds" value="240"/>
    <param name="retry-seconds" value="30"/>
    <param name="extension" value="$${webex_line_port}"/>
    <param name="context" value="public"/>
    <param name="caller-id-in-from" value="true"/>
    <variables>
      <variable name="rtp_secure_media" value="mandatory:AES_CM_128_HMAC_SHA1_80" direction="outbound"/>
      <variable name="rtp_secure_media" value="mandatory:AES_CM_128_HMAC_SHA1_80" direction="inbound"/>
    </variables>
  </gateway>
</include>

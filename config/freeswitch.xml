<?xml version="1.0" encoding="utf-8"?>
<configuration name="freeswitch.xml" description="FreeSWITCH">
  <global_settings>
    <param name="log-level" value="info"/>
    <param name="auto-create-sip-profiles" value="false"/>
  </global_settings>

  <X-PRE-PROCESS cmd="include" data="vars.xml"/>

  <section name="configuration" description="Various Configuration">
    <X-PRE-PROCESS cmd="include" data="autoload_configs/*.xml"/>
  </section>

  <section name="dialplan" description="Dialplan">
    <X-PRE-PROCESS cmd="include" data="dialplan/*.xml"/>
  </section>

  <section name="chatplan" description="Chatplan">
    <X-PRE-PROCESS cmd="include" data="chatplan/*.xml"/>
  </section>

  <section name="directory" description="User Directory">
    <X-PRE-PROCESS cmd="include" data="directory/*.xml"/>
  </section>

</configuration>
